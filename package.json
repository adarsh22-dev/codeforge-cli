{
  "name": "codeforge",
  "version": "0.1.0",
  "description": "A multi-provider coding-agent CLI — code with any LLM",
  "type": "module",
  "bin": {
    "codeforge": "./bin/codeforge"
  },
  "exports": {
    "./package.json": "./package.json",
    "./dist/cli.mjs": "./dist/cli.mjs",
    "./sdk": {
      "types": "./src/entrypoints/sdk.d.ts",
      "import": "./dist/sdk.mjs"
    }
  },
  "files": [
    "bin/",
    "dist/cli.mjs",
    "dist/sdk.mjs",
    "src/entrypoints/sdk.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "dev": "bun run build && node bin/codeforge",
    "start": "node bin/codeforge",
    "test": "bun test",
    "test:full": "bun test --max-concurrency=1",
    "test:coverage": "bun test --coverage --max-concurrency=1",
    "typecheck": "tsc --noEmit",
    "smoke": "bun run build && node dist/cli.mjs --version",
    "deadcode": "knip --include files,dependencies",
    "check": "bun run smoke && bun run test:full",
    "doctor:runtime": "bun run scripts/system-check.ts"
  },
  "dependencies": {
    "commander": "12.1.0",
    "chalk": "5.6.2",
    "react": "19.2.4",
    "ink": "7.1.0",
    "ink-text-input": "6.0.0",
    "zod": "3.25.76",
    "execa": "9.6.1",
    "cli-boxes": "3.0.0",
    "cli-highlight": "2.1.11",
    "marked": "15.0.12",
    "wrap-ansi": "9.0.2",
    "indent-string": "5.0.0",
    "figures": "6.1.0",
    "signal-exit": "4.1.0",
    "supports-hyperlinks": "3.2.0",
    "picomatch": "4.0.4",
    "ignore": "7.0.5",
    "diff": "8.0.3",
    "yaml": "2.8.3",
    "undici": "7.24.6",
    "chokidar": "4.0.3",
    "tree-kill": "1.2.2",
    "@modelcontextprotocol/sdk": "1.29.0",
    "https-proxy-agent": "7.0.6",
    "env-paths": "3.0.0",
    "semver": "7.7.4",
    "lru-cache": "11.2.7"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "typescript": "5.9.3",
    "knip": "^6.16.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT"
}
